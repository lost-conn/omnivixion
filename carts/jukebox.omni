omnivixion cart v0.1

__header__
[meta]
spec   = "0.1"
name   = "Jukebox"
author = "seth"
desc   = "music sequencer demo: 3 songs, channel masking, cross-fades, sfx on top"

[runtime]
lang = "lua"
hz   = 60

[display]
default_pitch  = 30
persist_buffer = false

__sfx__
# ---------------------------------------------------------------------------
#  SFX bank (8 slots) — most are music voices; a couple are for `sfx()` on top.
#
#  Slot map:
#    00 bass    — pulse bassline, loops a 4-step C/G figure (used by all songs)
#    01 lead_a  — triangle lead arpeggio for song A
#    02 lead_b  — square lead arpeggio for song B
#    03 pad     — organ pad for song B (3rd channel)
#    04 jingle  — short non-looping triangle motif for song C (one-shot)
#    05 chord   — second one-shot motif for song C's 2nd pattern
#    06 zap     — short noise sweep (button-6 one-shot)
#    07 ping    — bright triangle blip (button-6 alt)
# ---------------------------------------------------------------------------

sfx 00 bass
  speed=6 loop=none
  3018 3018 3818 3818 3018 3018 3818 3818
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000

sfx 01 lead_a
  speed=6 loop=none
  5418 5818 5c18 6018 5c18 5818 5418 5018
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000

sfx 02 lead_b
  speed=6 loop=none
  60d8 5cd8 58d8 54d8 50d8 54d8 58d8 5cd8
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000

sfx 03 pad
