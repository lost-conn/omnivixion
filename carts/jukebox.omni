  4c58 4c58 4c58 4c58 5058 5058 5058 5058
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000

sfx 04 jingle
  speed=6 loop=none
  4818 5018 5418 5818 6018 5818 5018 4818
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000
  0000 0000 0000 0000 0000 0000 0000 0000

sfx 05 chord
